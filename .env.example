# Copy this file to .env and fill in your actual keys.
# Never commit .env to git — it is listed in .gitignore.

# Required: Groq API key for Llama-3.3-70B reasoning engine
GROQ_API_KEY=your_groq_api_key_here

# Optional: Gemini API key (currently unused — key in environment is expired)
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API key (not used in this implementation)
# OPENAI_API_KEY=your_openai_api_key_here
